<?xml version="1.0" encoding="utf-8"?>
<!--
    Prevents Android Auto-Backup from backing up the encrypted DB and
    sensitive preferences. Users must re-authenticate after reinstall.
-->
<data-extraction-rules
    xmlns:android="http://schemas.android.com/apk/res/android">
    <cloud-backup>
        <exclude domain="database" path="cellosplit.db" />
        <exclude domain="database" path="cellosplit.db-shm" />
        <exclude domain="database" path="cellosplit.db-wal" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="cellosplit.db" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
